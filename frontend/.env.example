# Local migration only. Prefer running ../dev.sh, which generates and injects
# one ephemeral value into both C++ Compute and Vite automatically.
VITE_BACKEND_PORT=18080
VITE_COMPUTE_SERVICE_KEY=replace-with-the-same-value-as-FSD_COMPUTE_SERVICE_KEY

# Never inject VITE_COMPUTE_SERVICE_KEY into a commercial browser build.
# Production browsers call Platform /v1/*; only the Platform Worker holds the
# private Compute service credential.
