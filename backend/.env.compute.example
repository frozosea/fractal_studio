# Copy values into the container/orchestrator environment. The C++ service does
# not load this file by itself.
FSD_COMPUTE_SERVICE_KEY=replace-with-a-long-random-service-secret
FSD_RENDERER_VERSION=development
FSD_ENABLE_LEGACY_API=0
FSD_ENABLE_LEGACY_FORMULA_COMPILER=0
FSD_STARTUP_BENCHMARK=off
FSD_RENDER_THREADS=0
FSD_THERMAL_FRIENDLY=0

