# Local development values. Copy to .env; never commit production secrets.
APP_ENV=development
LOG_LEVEL=DEBUG

POSTGRES_USER=fractal
POSTGRES_PASSWORD=fractal_dev_password
POSTGRES_DB=fractal_platform
POSTGRES_PORT=15432
DATABASE_URL=postgresql+asyncpg://fractal:fractal_dev_password@postgres:5432/fractal_platform
MIGRATION_DATABASE_URL=postgresql+psycopg://fractal:fractal_dev_password@postgres:5432/fractal_platform

REDIS_PORT=16379
REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_password
MINIO_PORT=19000
MINIO_CONSOLE_PORT=19001
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:19000
S3_BUCKET=fractal-platform
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio_dev_password
# Keep empty in MinIO development. Production requires AES256 or aws:kms.
S3_SERVER_SIDE_ENCRYPTION=
S3_SSE_KMS_KEY_ID=

API_PORT=18000
SESSION_SECRET=dev-session-secret-change-me-32-bytes-minimum
SESSION_COOKIE_SECURE=false
SESSION_TTL_DAYS=30
API_ORIGIN=http://localhost:18000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
IDEMPOTENCY_LEASE_SECONDS=30
IDEMPOTENCY_TTL_HOURS=24

COMPUTE_BASE_URL=http://host.docker.internal:8080
COMPUTE_SERVICE_KEY=dev-compute-key-change-me
COMPUTE_CONNECT_TIMEOUT_SECONDS=5
COMPUTE_READ_TIMEOUT_SECONDS=60
PREVIEW_MAX_WIDTH=1024
PREVIEW_MAX_HEIGHT=1024

ALIPAY_APP_ID=
ALIPAY_SELLER_ID=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_PATH=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
ALIPAY_STUB_MODE=false
COMMISSION_POLICY_VERSION=mvp-v1
PLATFORM_FEE_BPS=2000
PAYMENT_ATTEMPT_TTL_MINUTES=30
PAYMENT_RECONCILE_DELAY_SECONDS=60

OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_LEASE_SECONDS=30
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_CLAIM_BATCH_SIZE=20
OUTBOX_SCHEDULE_INTERVAL_SECONDS=30
OUTBOX_BACKOFF_BASE_SECONDS=2
OUTBOX_BACKOFF_MAX_SECONDS=300
RENDER_POLL_INTERVAL_SECONDS=3
PREVIEW_MAX_PIXELS=1048576
PREVIEW_RATE_LIMIT_PER_MINUTE=30
RENDER_QUOTA_MAX_ACTIVE=3
RENDER_POLL_INTERVAL_SECONDS=3
MASTER_DOWNLOAD_TTL_SECONDS=300
PUBLIC_PREVIEW_TTL_SECONDS=3600
MEDIA_MAX_INPUT_BYTES=524288000
MEDIA_MAX_DERIVATIVE_BYTES=262144000
MEDIA_FFMPEG_TIMEOUT_SECONDS=120
MEDIA_TEMP_DIR=/tmp
ASSET_CLEANUP_RETRY_DELAY_SECONDS=300
PAYOUT_QR_TTL_SECONDS=600
PAYOUT_QR_REJECTED_RETENTION_DAYS=30
PAYOUT_QR_PAID_RETENTION_DAYS=90
